<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/svgs.css">
    <link rel="stylesheet" href="/individualProductStyle.css">
    <title><%= title %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
    <div class="global-wrapper">
        <%- include('navbar', { navLinks }) %>
        <div class="content">
            <a href="/products" class="btn"><%= btnTitle %></a>
            <div class="main-content">
                <div class="product-content">
                    <% if (product.url) { %>
                        <div class="product-image" style="background-image: <%= product.url %>"></div>
                    <% } else { %>
                        <div class="product-image" style="background: linear-gradient(to right, red, yellow);"></div>
                    <% } %>
                    <div class="product-info">
                        <div class="basic-info">
                            <div class="title-div">
                                <h1><%= product.name %></h1>
                                <h1>$<%= product.price %></h1>
                            </div>
                            <h2>
                                <% product.genre.forEach(item => { %>
                                    <% if(item !== product.genre[product.genre.length - 1]) { %>
                                        <%= item %>,
                                    <% } else { %>
                                        <%= item %>
                                    <% } %>
                                <% }) %>
                            </h2>
                        </div>
                        <p><%= product.description %></p>
                        <h4>
                            <% if (product.rating) { %>
                                <i>Majority of players rated this game <%= product.rating %>/10</i> &nbsp
                                <svg class="star star-big" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" id="star-1-svgrepo-com">
                                    <path d="M13.7309 3.51014L15.4909 7.03014C15.7309 7.52014 16.3709 7.99014 16.9109 8.08014L20.1009 8.61014C22.1409 8.95014 22.6209 10.4301 21.1509 11.8901L18.6709 14.3701C18.2509 14.7901 18.0209 15.6001 18.1509 16.1801L18.8609 19.2501C19.4209 21.6801 18.1309 22.6201 15.9809 21.3501L12.9909 19.5801C12.4509 19.2601 11.5609 19.2601 11.0109 19.5801L8.02089 21.3501C5.88089 22.6201 4.58089 21.6701 5.14089 19.2501L5.85089 16.1801C5.98089 15.6001 5.75089 14.7901 5.33089 14.3701L2.85089 11.8901C1.39089 10.4301 1.86089 8.95014 3.90089 8.61014L7.09089 8.08014C7.62089 7.99014 8.26089 7.52014 8.50089 7.03014L10.2609 3.51014C11.2209 1.60014 12.7809 1.60014 13.7309 3.51014Z" stroke="none" stroke-width="0" stroke-linecap="round" stroke-linejoin="round"></path>
                                </svg>
                            <% } else { %>
                                <i>Not out yet</i>
                            <% } %>
                        </h4>
                        <h3>Made by 
                            <% product.developers.forEach(dev => { %>
                                <% if(dev !== product.developers[product.developers.length - 1]) { %>
                                    <span><%= dev %></span>,
                                <% } else { %>
                                    <span><%= dev %></span>
                                <% } %>
                            <% }) %>
                        </h3>
                    </div>
                </div>

                <% if (product.isDefault === true) { %>
                    <div class="option-buttons">
                        <a href="/products/<%= product.id %>/update" class="btn">Update</a>
                        <a href="/products/<%= product.id %>/delete" class="btn">Delete</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
    <%- include('footbar') %>
</body>
</html>
