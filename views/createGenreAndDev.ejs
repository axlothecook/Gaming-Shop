<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/svgs.css">
    <link rel="stylesheet" href="/genreAndDevStyle.css">
    <title><%= title %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
    <div class="global-wrapper">
        <%- include('partials/navbar', { navLinks }) %>
        <% if (errors && errors.length !== 0) { %>
            <%- include('partials/errors', { errors }) %>
        <% } %>
        <div class="content">
            <a href="/category" class="btn"><%= btnTitle %></a>
            <form class="main-content for-edit" method="POST" action="/<%= path %>/new">
                <h1><%= title %></h1>
                <div class="main-content-child">
                    <div>
                        <label for="name">Name</label>
                        <input type="text" name="name" id="<%= title %>-id-create" autocomplete="off" required />
                    </div>
                    <div class="image-input-wrapper">
                        <label for="gameImg">Photo</label>
                        <input type="file" class="image-input" name="gameImg" accept="image/png, image/jpeg" required />
                    </div>
                </div>
                <button type="submit" class="btn">Done</button>
            </form>
        </div>
    </div>
    <%- include('partials/footbar') %>
</body>
</html>

<script>
    function testForError() {
        const error = document.getElementById('error-wrapper');
        if(document.body.contains(error)) {
            setTimeout(() => {
                error.style.display = 'none';
            }, 3000);
        };
    };

    testForError();
</script>