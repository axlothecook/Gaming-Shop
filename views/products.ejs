<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/svgs.css">
    <link rel="stylesheet" href="/productsPage.css">
    <title><%= title %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
    <div class="global-wrapper">
        <%- include('partials/navbar', { navLinks }) %>
        <div class="content">
            <div class="title-and-add-btn-div">
                <h1>Games</h1>
                <a href="/products/new">
                    <button class="add-btn">Add a <%= btnText %></button>
                </a>
            </div>
            <div class="main-content">
                <div class="filters-wrapper">
                    <section>
                        <div class="filter-category" onclick="toggleGenreDropDown()">
                            <h2>Genre</h2>
                            <svg class="filter-arrow" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 -4.5 20 20">
                                <defs></defs>
                                <g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                    <g id="Dribbble-Light-Preview" transform="translate(-220.000000, -6684.000000)" fill="#f5ebd0">
                                        <g id="icons" transform="translate(56.000000, 160.000000)">
                                            <path d="M164.292308,6524.36583 L164.292308,6524.36583 C163.902564,6524.77071 163.902564,6525.42619 164.292308,6525.83004 L172.555873,6534.39267 C173.33636,6535.20244 174.602528,6535.20244 175.383014,6534.39267 L183.70754,6525.76791 C184.093286,6525.36716 184.098283,6524.71997 183.717533,6524.31405 C183.328789,6523.89985 182.68821,6523.89467 182.29347,6524.30266 L174.676479,6532.19636 C174.285736,6532.60124 173.653152,6532.60124 173.262409,6532.19636 L165.705379,6524.36583 C165.315635,6523.96094 164.683051,6523.96094 164.292308,6524.36583" id="arrow_down-[#338]"></path>
                                        </g>
                                    </g>
                                </g>
                            </svg>
                        </div>
                        <form method="GET" action="/products" class="filter-form" id="genreListForm">
                            <% genresListArray.forEach(item => { %>
                                <button type="submit" class="filter-submit-btn" name="genre-<%= item.id %>" value="<%= item.checked %>">
                                    <% if (item.checked) { %>
                                        <svg class="check-type" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" id="checked">
                                            <path d="M8 12.5L10.5 15L16 9M7.2 20H16.8C17.9201 20 18.4802 20 18.908 19.782C19.2843 19.5903 19.5903 19.2843 19.782 18.908C20 18.4802 20 17.9201 20 16.8V7.2C20 6.0799 20 5.51984 19.782 5.09202C19.5903 4.71569 19.2843 4.40973 18.908 4.21799C18.4802 4 17.9201 4 16.8 4H7.2C6.0799 4 5.51984 4 5.09202 4.21799C4.71569 4.40973 4.40973 4.71569 4.21799 5.09202C4 5.51984 4 6.07989 4 7.2V16.8C4 17.9201 4 18.4802 4.21799 18.908C4.40973 19.2843 4.71569 19.5903 5.09202 19.782C5.51984 20 6.07989 20 7.2 20Z" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                                        </svg>
                                    <% } else { %>
                                        <svg class="check-type" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" id="unchecked">
                                            <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                                            <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g>
                                            <g id="SVGRepo_iconCarrier">
                                                <rect x="4" y="4" width="16" height="16" rx="2" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></rect>
                                            </g>
                                        </svg>
                                    <% } %>
                                    <h3><%= item.name %></h3>
                                    <h3>[ <%= item.numberOfGames %> ]</h3>
                                </button> 
                            <% }) %>
                        </form>
                    </section>
                    <section>
                        <div class="filter-category" onclick="toggleDevDropDown()">
                            <h2>Developer</h2>
                            <svg class="filter-arrow" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 -4.5 20 20">
                                <defs></defs>
                                <g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                                    <g id="Dribbble-Light-Preview" transform="translate(-220.000000, -6684.000000)" fill="#f5ebd0">
                                        <g id="icons" transform="translate(56.000000, 160.000000)">
                                            <path d="M164.292308,6524.36583 L164.292308,6524.36583 C163.902564,6524.77071 163.902564,6525.42619 164.292308,6525.83004 L172.555873,6534.39267 C173.33636,6535.20244 174.602528,6535.20244 175.383014,6534.39267 L183.70754,6525.76791 C184.093286,6525.36716 184.098283,6524.71997 183.717533,6524.31405 C183.328789,6523.89985 182.68821,6523.89467 182.29347,6524.30266 L174.676479,6532.19636 C174.285736,6532.60124 173.653152,6532.60124 173.262409,6532.19636 L165.705379,6524.36583 C165.315635,6523.96094 164.683051,6523.96094 164.292308,6524.36583" id="arrow_down-[#338]"></path>
                                        </g>
                                    </g>
                                </g>
                            </svg>
                        </div>
                        <form method="GET" action="/products" class="filter-form" id="devsListForm">
                            <% devsListArray.forEach(item => { %>
                                <button type="submit" class="filter-submit-btn" name="dev-<%= item.id %>" value="<%= item.checked %>">
                                    <% if (item.checked) { %>
                                        <svg class="check-type" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" id="checked">
                                            <path d="M8 12.5L10.5 15L16 9M7.2 20H16.8C17.9201 20 18.4802 20 18.908 19.782C19.2843 19.5903 19.5903 19.2843 19.782 18.908C20 18.4802 20 17.9201 20 16.8V7.2C20 6.0799 20 5.51984 19.782 5.09202C19.5903 4.71569 19.2843 4.40973 18.908 4.21799C18.4802 4 17.9201 4 16.8 4H7.2C6.0799 4 5.51984 4 5.09202 4.21799C4.71569 4.40973 4.40973 4.71569 4.21799 5.09202C4 5.51984 4 6.07989 4 7.2V16.8C4 17.9201 4 18.4802 4.21799 18.908C4.40973 19.2843 4.71569 19.5903 5.09202 19.782C5.51984 20 6.07989 20 7.2 20Z" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                                        </svg>
                                    <% } else { %>
                                        <svg class="check-type" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" id="unchecked">
                                            <g id="SVGRepo_bgCarrier" stroke-width="0"></g>
                                            <g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g>
                                            <g id="SVGRepo_iconCarrier">
                                                <rect x="4" y="4" width="16" height="16" rx="2" stroke="#000000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></rect>
                                            </g>
                                        </svg>
                                    <% } %>
                                    <h3><%= item.name %></h3>
                                    <h3>[ <%= item.numberOfGames %> ]</h3>
                                </button> 
                            <% }) %>
                        </form>
                    </section>
                </div>
                <div class="products-list">
                    <%- include('partials/productCard', { productsArray }) %>
                </div>
            </div>
        </div>
    </div>
    <%- include('partials/footbar') %>
</body>
</html>

<script>
    const dropDownGenre = document.getElementById('genreListForm');
    const dropDownDev = document.getElementById('devsListForm');
    let genreCounter = false;
    let devsCounter = false;
    const toggleGenreDropDown = () => {
        genreCounter = !genreCounter;
        genreCounter ? dropDownGenre.style.display = 'flex' : dropDownGenre.style.display = 'none';
    };
    const toggleDevDropDown = () => {
        devsCounter = !devsCounter;
        devsCounter ? dropDownDev.style.display = 'flex' : dropDownDev.style.display = 'none';
    };
</script>
