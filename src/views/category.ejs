<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="stylesheet" href="/svgs.css">
    <link rel="stylesheet" href="/categoriesStyle.css">
    <title><%= title %></title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
</head>
<body>
    <div class="global-wrapper">
        <%- include('partials/navbar', { navLinks }) %>
        <div class="content">
            <section>
                <div class="title-and-add-btn-div">
                    <h1><%= title %></h1>
                    <a href="/<%= path %>/new">
                        <button class="add-btn">Add New</button>
                    </a>
                </div>
                <div class="category-wrapper">
                    <% arr.forEach(item => { %>
                        <a href="/<%= path %>/<%= item._id.toString() %>">
                            <div class="category-card" style="background-image: <%= item.url %>">
                                <% if (path !== 'developers') { %>
                                    <div class="genre-card">
                                        <h3><%= item.name %></h3>
                                    </div>
                                <% } %>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </section>
        </div>
    </div>
    <%- include('partials/footbar') %>
</body>
</html>